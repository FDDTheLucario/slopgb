#!/usr/bin/env sh
# Pre-commit gate — rustfmt + clippy MUST pass or the commit is blocked.
# Mirrors the CI checks (.github/workflows/ci.yml) so formatting/lint drift is
# caught locally instead of on main. Uses the pinned toolchain
# (rust-toolchain.toml), so CI and this hook run the identical rustc/clippy.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
#
# Bypass for an emergency WIP commit (discouraged): git commit --no-verify
set -e

echo "pre-commit: cargo fmt --all --check"
cargo fmt --all --check

echo "pre-commit: cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

# The guest plugin SDK ships to wasm32; the host-target run above does not
# cross-compile it, so lint it for its real target too.
echo "pre-commit: cargo clippy -p slopgb-plugin-api --target wasm32-unknown-unknown -- -D warnings"
cargo clippy -p slopgb-plugin-api --target wasm32-unknown-unknown -- -D warnings

echo "pre-commit: OK"
